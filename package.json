    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@ngx-env/builder": "^21.0.1",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tsx": "^4.22.4",
